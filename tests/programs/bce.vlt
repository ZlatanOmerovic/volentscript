// P24: bounds-check elimination via loop versioning. Results must be
// identical whether the entry guard sends execution down the fast
// (unchecked) or slow (checked) loop, and an out-of-range counted loop must
// still raise RangeError through the slow path.

var a:Vector.<Number> = new <Number>[];
for (var i:int = 0; i < 5; i++) {
    a[i] = i * 2.0;              // appends (guard false → checked slow path)
}

var s:Number = 0.0;
for (var i:int = 0; i < 5; i++) {
    s += a[i];                  // in range (guard true → unchecked fast path)
}
trace(s);                        // 0+2+4+6+8 = 20

var t:Number = 0.0;
for (var i:int = 0; i <= 4; i++) {
    t += a[i];                  // inclusive counted loop, still in range
}
trace(t);                        // 20

for (var i:int = 0; i < 5; i++) {
    a[i] = a[i] + 1.0;          // fast read + fast write
}
trace(a.join(","));              // 1,3,5,7,9

// Guard-false safety: the bound exceeds the length, so the guard routes to
// the checked loop, which raises RangeError at the first out-of-range index.
var b:Vector.<int> = new <int>[10, 20, 30];
try {
    var sum:int = 0;
    for (var i:int = 0; i < 5; i++) {
        sum += b[i];
    }
    trace(sum);
} catch (e:RangeError) {
    trace("caught oob");
}
