/target
.DS_Store

# Reference material is read-only *input*, not a code artifact (CLAUDE.md §5).
# SOURCES.md stays tracked so the set is reproducible; see links.md.
/docs/*
!/docs/SOURCES.md

# Compiled test binaries never land in git; sources + goldens do.
/tests/showcase
/tests/programs/*
!/tests/programs/*.vlt
!/tests/programs/*.out
!/tests/programs/*.txt

# Example build outputs (any extensionless file next to a .vlt source)
/examples/*/main
/examples/*/server
/examples/*/client
/examples/*/smtpd
/examples/*/send
